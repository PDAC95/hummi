# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.
#
# IMPORTANT: only variables prefixed with VITE_ are exposed to the browser.
# NEVER prefix a secret key with VITE_. Secrets go in Supabase Edge Functions
# or Vercel server env (without the VITE_ prefix).

# Supabase (frontend-safe keys)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Stripe — PUBLISHABLE key only (safe for the browser)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Stripe secret key: do NOT put it here.
# Store it in Supabase Edge Functions secrets (`supabase secrets set STRIPE_SECRET_KEY=...`)
# or Vercel server environment variables (without VITE_ prefix).
