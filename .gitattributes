# Force LF line endings for shell scripts and YAML so they work on Ubuntu CI
# regardless of the contributor's local core.autocrlf setting.
*.sh         text eol=lf
*.bash       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf

# SQL migrations: LF too — psql tolerates either, but consistency helps diffs.
*.sql        text eol=lf
